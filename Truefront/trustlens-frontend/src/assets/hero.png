<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 600" width="1200" height="600">
  <!-- Gradient Background -->
  <defs>
    <linearGradient id="heroGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#004ac6;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#0066e6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1f3a93;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="accentGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#10b981;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#059669;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="600" fill="url(#heroGradient)" />

  <!-- Decorative circles -->
  <circle cx="100" cy="150" r="80" fill="rgba(255,255,255,0.1)" />
  <circle cx="1100" cy="450" r="120" fill="rgba(255,255,255,0.08)" />
  <circle cx="600" cy="50" r="60" fill="rgba(16,185,129,0.15)" />

  <!-- Left side: Illustration area -->
  <g>
    <!-- Scale/Balance icon (representing fairness) -->
    <g transform="translate(150, 200)">
      <!-- Balance beam -->
      <rect x="80" y="140" width="80" height="8" fill="#10b981" rx="4" />
      <!-- Fulcrum -->
      <path d="M 120 140 L 110 160 L 130 160 Z" fill="#10b981" />
      
      <!-- Left scale -->
      <g transform="translate(20, 120)">
        <rect x="0" y="20" width="50" height="40" fill="rgba(255,255,255,0.2)" rx="4" />
        <text x="25" y="50" text-anchor="middle" fill="white" font-size="16" font-weight="bold">Fair</text>
      </g>
      
      <!-- Right scale -->
      <g transform="translate(160, 120)">
        <rect x="0" y="20" width="50" height="40" fill="rgba(255,255,255,0.2)" rx="4" />
        <text x="25" y="50" text-anchor="middle" fill="white" font-size="16" font-weight="bold">AI</text>
      </g>
    </g>

    <!-- People/Candidates illustration -->
    <g transform="translate(80, 380)">
      <!-- Person 1 -->
      <circle cx="30" cy="20" r="12" fill="rgba(255,255,255,0.3)" />
      <path d="M 20 35 L 20 60 M 30 40 L 15 50 M 30 40 L 45 50 M 20 60 L 15 85 M 20 60 L 25 85" stroke="rgba(255,255,255,0.3)" stroke-width="3" fill="none" stroke-linecap="round" />
      
      <!-- Person 2 -->
      <circle cx="80" cy="20" r="12" fill="rgba(255,255,255,0.3)" />
      <path d="M 70 35 L 70 60 M 80 40 L 65 50 M 80 40 L 95 50 M 70 60 L 65 85 M 70 60 L 75 85" stroke="rgba(255,255,255,0.3)" stroke-width="3" fill="none" stroke-linecap="round" />
      
      <!-- Person 3 -->
      <circle cx="130" cy="20" r="12" fill="rgba(255,255,255,0.3)" />
      <path d="M 120 35 L 120 60 M 130 40 L 115 50 M 130 40 L 145 50 M 120 60 L 115 85 M 120 60 L 125 85" stroke="rgba(255,255,255,0.3)" stroke-width="3" fill="none" stroke-linecap="round" />
    </g>
  </g>

  <!-- Right side: Text content -->
  <g transform="translate(500, 150)">
    <!-- Main heading -->
    <text x="0" y="0" font-size="56" font-weight="bold" fill="white" font-family="Arial, sans-serif">
      TrustLens
    </text>
    
    <!-- Subheading -->
    <text x="0" y="70" font-size="28" fill="rgba(255,255,255,0.9)" font-family="Arial, sans-serif">
      Fair AI Recruitment
    </text>
    
    <!-- Description -->
    <text x="0" y="120" font-size="16" fill="rgba(255,255,255,0.85)" font-family="Arial, sans-serif" font-weight="300">
      Eliminate bias. Build diverse teams. Make fair hiring decisions.
    </text>

    <!-- Feature list -->
    <g transform="translate(0, 180)">
      <!-- Feature 1 -->
      <g>
        <circle cx="12" cy="12" r="6" fill="url(#accentGradient)" />
        <text x="30" y="18" font-size="14" fill="white" font-family="Arial, sans-serif">Detect and analyze hiring bias</text>
      </g>
      
      <!-- Feature 2 -->
      <g transform="translate(0, 40)">
        <circle cx="12" cy="12" r="6" fill="url(#accentGradient)" />
        <text x="30" y="18" font-size="14" fill="white" font-family="Arial, sans-serif">Compare candidates fairly</text>
      </g>
      
      <!-- Feature 3 -->
      <g transform="translate(0, 80)">
        <circle cx="12" cy="12" r="6" fill="url(#accentGradient)" />
        <text x="30" y="18" font-size="14" fill="white" font-family="Arial, sans-serif">Generate unbiased reports</text>
      </g>
    </g>
  </g>

  <!-- Bottom accent bar -->
  <rect y="550" width="1200" height="50" fill="rgba(16,185,129,0.2)" />
  <text x="600" y="585" text-anchor="middle" font-size="14" fill="rgba(255,255,255,0.8)" font-family="Arial, sans-serif">
    Powered by advanced bias detection technology
  </text>
</svg>
